# --- copy to .env and edit for your setup ---
#
# IPs both ends use as DDS peers (and what shows on the dashboard).
LOCAL_IP=100.106.58.57
CLOUD_IP=100.68.31.50

# Display labels shown in the dashboard topology view.
LOCAL_HOSTNAME=merabro24lts
CLOUD_HOSTNAME=prakash

# How the local container reaches the cloud over SSH.
CLOUD_SSH_HOST=workstations22lts.tail7f2e03.ts.net
CLOUD_USER=merabro
SSH_KEY_PATH=~/.ssh/id_ed25519

# Network interface DDS binds to on both sides. Must exist on both
# (e.g. tailscale0, wg0, eth0).
DDS_INTERFACE=tailscale0

ROS_DOMAIN_ID=0
